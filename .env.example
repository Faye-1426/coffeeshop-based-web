# Supabase (Vite exposes only VITE_* to the browser)
VITE_SUPABASE_URL=********
VITE_SUPABASE_ANON_KEY=********
VITE_CUSTOMER_DEFAULT_TENANT_SLUG=my-outlet
# Customer marketplace: redirect `/` to `/${slug}-store` (slug = tenants.slug, no suffix)
# Never put the service role key in VITE_* or commit it.
# Use only in CI/server scripts if needed:
# SUPABASE_SERVICE_ROLE_KEY=

# Edge Functions (Supabase Dashboard → Edge Functions → Secrets), not VITE_*:
# MIDTRANS_PRODUCTION=false   # sandbox API (app.sandbox.midtrans.com)
# MIDTRANS_PRODUCTION=true    # production API — use production server/client keys in tenant blob

# DB stores Base64(JSON.stringify({ serverKey, clientKey })). In the app you can paste JSON or Base64; the client encodes JSON before RPC.
